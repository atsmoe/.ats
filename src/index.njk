---
permalink: ./index.html
title: 群星之间
bodyClass: world-index
pageType: star-map
cssFiles:
  - base.css
  - nav.css
  - star-map.css
  - worlds.css
  - responsive.css
---
{% extends "base.njk" %}

{% block content %}
<!-- Star Map View -->
<div id="star-map">
  <!-- 3D cluster markers (positioned by star-map-3d.js) -->
  <div id="galaxy-markers">
    <div class="galaxy-marker" id="marker-arknights" data-world="arknights">
      <div class="galaxy-marker-glow" style="--marker-color: #d4923a;"></div>
      <div class="galaxy-marker-core" style="--marker-color: #d4923a;"></div>
      <div class="galaxy-marker-label">泰拉大陆</div>
    </div>
    <div class="galaxy-marker" id="marker-wh40k" data-world="wh40k">
      <div class="galaxy-marker-glow" style="--marker-color: #c85050;"></div>
      <div class="galaxy-marker-core" style="--marker-color: #c85050;"></div>
      <div class="galaxy-marker-label">神圣泰拉</div>
    </div>
    <div class="galaxy-marker" id="marker-ff14" data-world="ff14">
      <div class="galaxy-marker-glow" style="--marker-color: #b8c4d8;"></div>
      <div class="galaxy-marker-core" style="--marker-color: #b8c4d8;"></div>
      <div class="galaxy-marker-label">艾欧泽亚</div>
    </div>
  </div>

  <!-- Galaxy hover tooltip -->
  <div class="galaxy-tooltip" id="galaxy-tooltip">
    <div class="gt-name" id="gt-name"></div>
    <div class="gt-sub" id="gt-sub"></div>
    <div class="gt-hint">点击查看详情</div>
  </div>
</div>

<!-- Galaxy detail overlay -->
<div id="galaxy-detail">
  <div class="detail-overlay" id="detail-overlay"></div>
  <button class="detail-close" id="detail-close">✕</button>
  <div class="detail-content">
    <div class="detail-body">
      <canvas id="galaxy-canvas" width="640" height="640"></canvas>
    </div>
    <div class="detail-title" id="detail-title"></div>
    <div class="detail-sub" id="detail-sub"></div>
    <p class="detail-desc" id="detail-desc"></p>
    <div class="detail-calendar" id="detail-calendar"></div>
    <button class="btn-detail-enter" id="detail-enter-btn">进 入 编 年 史</button>
  </div>
</div>
{% endblock %}