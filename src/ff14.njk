cssFiles:
  - base.css
  - nav.css
  - timeline.css
  - ref-panel.css
  - worlds.css
  - responsive.css
---
{% extends "base.njk" %}

{% block content %}
<!-- Timeline View -->
<div id="timeline" class="active">
  <div class="tl-cover">
    <div class="tl-cover-inner">
      <h1>最终幻想XIV · 艾欧泽亚</h1>
      <p>十四个世界同归一源。从万物的分裂到光暗的终末之战，水晶的意志指引着冒险者穿越星海、横跨折射——在原初世界与碎片世界之间，铭刻每一个灵魂的足迹。</p>
      <div class="calendar-badge">伊 修 加 德 历</div>
    </div>
  </div>

  <div class="tl-branches" id="tl-branches">
    <!-- Populated by JS -->
  </div>
  <div class="tl-sub-branches" id="tl-sub-branches" style="display:none;">
    <!-- Populated by JS when shard group is selected -->
  </div>
  <button class="tl-archive-toggle" id="tl-archive-toggle">秘话 · 设定</button>

  <div class="tl-container" id="tl-container">
    <!-- Events injected by JS -->
  </div>

  <!-- Archive view (anecdotes + lore, not a timeline branch) -->
  <div class="archive-view" id="archive-view" style="display:none;">
    <div class="archive-tabs" id="archive-tabs"></div>
    <div class="archive-content" id="archive-content"></div>
  </div>

</div>

<!-- Event Detail Modal -->
<div id="event-modal" class="event-modal-overlay" style="display:none;">
  <div class="event-modal-card">
    <button class="event-modal-close" title="关闭">✕</button>
    <div class="event-modal-date"></div>
    <div class="event-modal-title"></div>
    <div class="event-modal-meta"></div>
    <div class="event-modal-desc"></div>
    <div class="event-modal-img"></div>
    <div class="event-modal-sources"></div>
  </div>
</div>

<!-- Overlay & Reference Panel -->
<div id="overlay"></div>
<div id="ref-panel">
  <button class="ref-close" id="ref-close">✕</button>
  <div class="ref-content">
    <h2>跨 世 界 引 用</h2>
    <div class="ref-world-label" id="ref-world-label">—— 跨世界引用 ——</div>
    <div class="ref-event-date" id="ref-event-date"></div>
    <div class="ref-event-title" id="ref-event-title"></div>
    <div class="ref-event-desc" id="ref-event-desc"></div>
    <div class="ref-related">
      <h3>关联事件</h3>
      <a href="#">▸ 引用事件</a>
    </div>
    <button class="btn-wormhole" id="btn-wormhole">穿 越 虫 洞</button>
  </div>
</div>

<!-- Era sidebar navigation -->
<nav id="era-nav"></nav>

<!-- Back to top -->
<button id="back-to-top" title="回到顶部">▲</button>
{% endblock %}

{% block extraScripts %}
<script src="./js/virtual-timeline.js"></script>
{% endblock %}